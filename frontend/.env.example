# ASP.NET Core API base URL, without a trailing slash.
# For a phone demo, set this to the HTTPS tunnel URL.
VITE_API_URL=http://localhost:5000

# For a phone demo, use the public HTTPS URL of the backend tunnel.
# Example: VITE_API_URL=https://your-backend-tunnel.example

# Optional host-only Spotify Web Playback integration.
# Create a Spotify app and add the exact HTTPS output URL as a Redirect URI.
# Leave these unset to keep the local AI-DJ audio engine as the only source.
# VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id
# VITE_SPOTIFY_REDIRECT_URI=https://your-ngrok-host.ngrok-free.dev/output.html

# Optional host-only Apple MusicKit on the Web integration.
# Use a signed Apple Music developer token and a two-letter storefront code.
# VITE_APPLE_MUSIC_DEVELOPER_TOKEN=your-signed-apple-music-developer-token
# VITE_APPLE_MUSIC_STOREFRONT=us

# Optional host-only YouTube Music playback through the official IFrame player.
# Enable YouTube Data API v3 and restrict this browser key by origin.
# VITE_YOUTUBE_API_KEY=your-youtube-data-api-key
